
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8001
LOG_LEVEL=INFO

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=talent_finder
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20

MONGO_URI=mongodb://localhost:27017
MONGO_DB=talent_finder
MONGO_CANDIDATES_COLLECTION=candidates

CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=candidate_skills


CORE_SERVICE_URL=http://localhost:8000
CORE_SERVICE_TIMEOUT=30
CORE_SERVICE_MAX_RETRIES=3

EMBEDDING_MODEL=all-MiniLM-L6-v2

SCRAPER_HEADLESS=true
SCRAPER_MIN_DELAY=2
SCRAPER_MAX_DELAY=7
SCRAPER_PAGE_TIMEOUT=30
LINKEDIN_SESSION_COOKIE=       # optional: persist login cookie
PROXY_URL=                     # optional: http://user:pass@host:port

SCHEDULER_POLL_INTERVAL=60


OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=talent_finder_backend_sourcing
PROMETHEUS_PORT=9001